<%- include ("header") %>


<h1>Ajout de produit</h1>


<div class="container">

    <form action="/admin/ajout_produit" method="POST" enctype="multipart/form-data">

        <div class="grid">

            <div class="image-upload">
                <label>
                    <input type="file" name="image" hidden>
                    <div class="upload-box">
                        <p>Téléverser une image</p>
                    </div>
                </label>
            </div>

            <div class="infos">

                <div class="row">
                    <div>
                        <label>Nom du produit</label>
                        <input type="text" name="nom_produit" required>
                    </div>

                    <div>
                        <label>Catégorie</label>
                        <select name="domaine" required>
                            <% domaines.forEach(d => { %>
                                <option value="<%= d.domaine %>"><%= d.domaine %></option>
                            <% }) %>
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div>
                        <label>Prix</label>
                        <input type="number" name="prix" step="0.01" required>
                    </div>

                    <div>
                        <label>Type</label>
                        <select name="type">
                            <% types.forEach(t => { %>
                                <option value="<%= t.type %>"><%= t.type %></option>
                            <% }) %>
                        </select>
                    </div>
                </div>

                <div>
                    <label>Caractéristiques</label>
                    <textarea name="variete"></textarea>
                </div>


            </div>
        </div>

        

        <div class="full">
            <label>Description</label>
            <textarea name="description"></textarea>
        </div>

        <div class="checkbox">
            <label>
                <input type="checkbox" name="disponibilite">
                Disponible
            </label>
        </div>

        <button type="submit">Valider</button>

    </form>

</div>


<script>
    const input = document.querySelector('input[type="file"]');
    const uploadBox = document.querySelector('.upload-box');

    input.addEventListener('change', function () {
        const file = this.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function (e) {
                uploadBox.innerHTML = `<img src="${e.target.result}" style="width:100%; height:100%; object-fit:cover; border-radius:8px;">`;
            };
            reader.readAsDataURL(file);
        }
    });
</script>
Ce que ça fait : dès que tu sélectionnes un fichier, il le lit localement (sans l'uploader) et affiche un aperçu directement dans la upload-box à la place du texte "Téléverser une image". L'image n'est réellement uploadée sur le serveur qu'au moment où tu cliques sur "Valider", comme avant.



<%- include ("footer") %>