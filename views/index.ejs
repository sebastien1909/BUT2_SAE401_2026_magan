<body>
    <div class="index-top-pic">
        <%- include("header") %>
            <div class="index-title">
                <div class="first-row">
                    <h1>Magañ</h1>
                    <h2 class="white">l'atelier végétal</h2>
                </div>
                <div class="second-row">
                    <h3 class="white">
                        Cultiver le vivant, éveiller les sens
                    </h3>
                </div>

            </div>
    </div>

    <section class="presentation">

        <div class="presentation-first-column">
            <h2 class="black">L'atelier végétal</h2>
            <div class="separateur"></div>
            <p>
                Magañ c’est tout d’abord un projet mais ce n’est pas un projet comme les autres, mené par Camille
                Montier,
                ce projet est divisé en plusieurs catégories et regroupe le maraîchage diversifié, la transformation,
                l’arboriculture ainsi qu’une pépinière spécialisé.
            </p>
            <a class="voir-plus" href="presentation"> Voir plus</a>
        </div>
        <div class="presentation-second-column">
            <img src="/img/presentation_picture.png" alt="Présentation de l'atelier végétal">
        </div>

    </section>

    <section class="liste-categorie">
        <div>
            <h2 class="white">Découvrez nos catégories</h2>
            <div class="separateur-white"></div>
        </div>

        <div class="boutons-categories">
            <a href="catalogue_produit?valeur=pepiniere" class="categorie-lien">
                <img src="/img/pepiniere.png" class="categorie-illu">
                <h3>Pépinière spécialisée</h3>
            </a>
            <a href="catalogue_produit?valeur=arboriculture" class="categorie-lien">
                <img src="/img/arboriculture.png" class="categorie-illu">
                <h3>Arboriculture</h3>
            </a>
            <a href="catalogue_produit?valeur=maraichage" class="categorie-lien">
                <img src="/img/maraichage.png" class="categorie-illu">
                <h3>Maraichage diversifié</h3>
            </a>
            <a href="catalogue_produit?valeur=transformation" class="categorie-lien">
                <img src="/img/transfo.png" class="categorie-illu">
                <h3>Transformation</h3>
            </a>
        </div>

    </section>

    <section class="horaire">
    <div class="horaire-first-column">
        <div class="map"></div>
        <a class="aller" href="#">J'y vais !</a>
    </div>

    <div class="horaire-second-column">
        <h2>Nos horaires</h2>
        <div class="separateur"></div>

        <div class="second-column-info-cont">
            <div class="info-cont-column">
                <div class="title-wrapper">
                    <i class="fa-solid fa-store" style="color: #98e39d;"></i>
                    <h3 class="black">Cette semaine</h3>
                </div>
            </div>

            <div class="info-cont-column">
                <div class="title-wrapper">
                    <i class="fa-solid fa-location-dot" style="color: #98e39d;"></i>
                    <h3 class="black">Où nous retrouver</h3>
                </div>
                <p class="address">5 Calvin, 22170<br>Lanrodec</p>
            </div>
        </div>
    </div>
</section>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script>
        const lat = 48.516944;
        const lng = -3.029722;

        const map = L.map('map').setView([lat, lng], 15);

        L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '&copy; OpenStreetMap'
        }).addTo(map);

        L.marker([lat, lng]).addTo(map)
            .bindPopup("<b>Magañ - l'atelier végétal</b><br>5 Calvin<br>22170 Lanrodec");
    </script>


    <%- include("footer") %>
 
     <!-- Leaflet CSS -->
    <link
        rel="stylesheet"
        href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
        crossorigin=""
    />

    <!-- Style de la carte (adapter la hauteur à ton design) -->
    <style>
        #map {
            height: 250px;
            width: 100%;
            border-radius: 8px;
            overflow: hidden;
        }
    </style>

    <!-- Leaflet JS -->
    <script
        src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
        integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
        crossorigin=""
    ></script>

    <script>
        // Coordonnées approximatives de Lanrodec (centre de la commune)
        const lat = 48.516944;
        const lng = -3.029722;

        const map = L.map("map").setView([lat, lng], 15);

        L.tileLayer("https://tile.openstreetmap.org/{z}/{x}/{y}.png", {
            maxZoom: 19,
            attribution:
                '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>'
        }).addTo(map);

        const marker = L.marker([lat, lng]).addTo(map);

        marker.bindPopup(
            "<b>Magañ - l'atelier végétal</b><br>5 Calvin<br>22170 Lanrodec"
        );
    </script>
</body>
</html>